# ============================================================
# NEXTGEM VOLUNTEER PLATFORM - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to `.env.local` and fill in your real values.
# These values are required for the platform to work.
# DO NOT commit `.env.local` to git (it contains secrets).
# ============================================================

# ---------------------------------------------------------
# SUPABASE (REQUIRED)
# ---------------------------------------------------------
# Get these from: Supabase Dashboard -> Project Settings -> API
# Both keys are required for authentication and database access.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key is used server-side only (for admin operations like syncing
# data to the Internal Operations Platform). NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------
# INTERNAL OPERATIONS PLATFORM SYNC (REQUIRED FOR PHASE 2)
# ---------------------------------------------------------
# Once the Internal Operations Platform is built, set this to its base URL.
# The volunteer platform will push volunteer hours, flags, and certificates
# to this URL automatically. For now, leave it blank or set to a placeholder.

NEXT_PUBLIC_INTERNAL_PLATFORM_URL=
INTERNAL_PLATFORM_API_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------
# RESEND (REQUIRED FOR EMAILS - e.g. certificates)
# ---------------------------------------------------------
# Get an API key from: https://resend.com/api-keys
# Only used server-side.

RESEND_API_KEY=
CERTIFICATE_FROM_EMAIL=certificates@nextgemfoundation.com

# ---------------------------------------------------------
# WHATSAPP / TWILIO (OPTIONAL - for sending certificates via WhatsApp)
# ---------------------------------------------------------
# If you want to send certificates via WhatsApp, fill these in.
# Otherwise leave blank - the platform will still work via email/download.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------------------------------------------------------
# APP CONFIGURATION
# ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NextGem Volunteer Platform
