# ─── Supabase ───────────────────────────────────────────────────────────────
# Copy these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Internal Operations Platform ───────────────────────────────────────────
# The URL of the Internal Ops platform so we can POST volunteer hours to it
INTERNAL_PLATFORM_API_URL=https://admin.nextgemfoundation.com/api
INTERNAL_PLATFORM_API_SECRET=your_shared_secret_key

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://volunteer.nextgemfoundation.com
